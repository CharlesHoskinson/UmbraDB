{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "chain-archive-sync/**/*.ts",
    "bench/**/*.ts"
  ]
}
